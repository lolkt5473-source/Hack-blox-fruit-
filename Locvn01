-- Loop xử lý các tính năng
local function onTick()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChild("Humanoid")
    if not hrp or not humanoid then return end
    
    -- Bay
    if fly then
        local flyVel = Vector3.new(0,0,0)
        if mouse.Target then
            local dir = (mouse.Hit.Position - hrp.Position).Unit
            flyVel = dir * 50
        end
        hrp.Velocity = Vector3.new(flyVel.X, flyVel.Y + (workspace.CurrentCamera.CFrame.UpVector.Y * 30), flyVel.Z)
        humanoid.PlatformStand = true
    else
        if humanoid.PlatformStand then humanoid.PlatformStand = false end
    end
    
    -- Xuyên tường
    if noclip then
        hrp.CanCollide = false
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    else
        if hrp.CanCollide == false then hrp.CanCollide = true end
    end
    
    -- Nhảy vô hạn
    if infiniteJump then
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
        humanoid.JumpPower = jumpPower
    end
    
    -- Tốc độ
    humanoid.WalkSpeed = speedHack
    
    -- Nhiên liệu vô hạn: tìm giá trị Fuel trong VehicleSeat hoặc IntValue
    local vehicleSeat = char:FindFirstChildWhichIsA("VehicleSeat")
    if vehicleSeat and fuelInf then
        local fuelVal = vehicleSeat:FindFirstChild("Fuel")
        if fuelVal and fuelVal:IsA("NumberValue") then
            fuelVal.Value = 100
        end
        -- Cách khác: ghi đè thuộc tính
        if vehicleSeat:GetAttribute("Fuel") then
            vehicleSeat:SetAttribute("Fuel", 100)
        end
    end
    
    -- Lốp bất tử
    if tireInf then
        for _, tire in pairs(char:GetDescendants()) do
            if tire.Name:lower():find("tire") or tire.Name:lower():find("wheel") then
                if tire:IsA("BasePart") then
                    tire.BrickColor = BrickColor.new("Bright green")
                    -- ngăn hỏng
                    local breakable = tire:FindFirstChild("Breakable")
                    if breakable then breakable:Destroy() end
                end
            end
        end
    end
    
    -- Auto sửa xe
    if instantRepair then
        -- giả sử game có RemoteEvent sửa xe
        local repairRemote = game.ReplicatedStorage:FindFirstChild("RepairVehicle")
        if repairRemote then repairRemote:FireServer() end
    end
    
    -- Tự động đổ xăng
    if autoFuel then
        local gasStation = workspace:FindFirstChild("GasStation")
        if gasStation and (hrp.Position - gasStation.Position).Magnitude < 30 then
            -- trigger mua xăng
            local buyFuel = game.ReplicatedStorage:FindFirstChild("BuyFuel")
            if buyFuel then buyFuel:FireServer() end
        end
    end
    
    -- Auto farm coin (tìm coin trong workspace)
    if autoFarmCoin then
        for _, coin in pairs(workspace:GetDescendants()) do
            if coin:IsA("BasePart") and (coin.Name:lower():find("coin") or coin.Name:lower():find("money")) then
                if (hrp.Position - coin.Position).Magnitude < 100 then
                    hrp.CFrame = coin.CFrame
                    task.wait(0.1)
                end
            end
        end
    end
end

