--[[
    BƯỚC 2: HÀNH VI MAY MẮN (HOOK RANDOM FRUIT)
    A) Ghi đè hàm random của game
    B) Tính tỷ lệ dựa trên tham số luck
    C) Force spawn trái xịn (Leopard, Dragon, Dough, Venom, Spirit, Control)
--]]
local luckMultiplier = 1000
local isActive = false

local rareFruits = {
    "Leopard", "Dragon", "Dough", "Venom", "Spirit", "Control", "Shadow", "Rumble"
}

-- Hook vào RemoteEvent khi player nhận trái cây từ dealer hoặc roll
local origRoll
if game.ReplicatedStorage:FindFirstChild("RollFruit") then
    origRoll = game.ReplicatedStorage.RollFruit.OnClientInvoke
end

local function getRandomFruit()
    local rng = math.random(1, 100000)
    -- Với luckMultiplier = 1000, cơ hội trái xịn gần như 100%
    local chance = math.min(100000, 1000 * luckMultiplier) -- tối đa 100000
    if rng <= chance then
        local rare = rareFruits[math.random(1, #rareFruits)]
        return rare
    else
        -- Trả về trái thường nếu lỡ không đủ
        local common = {"Bomb", "Spike", "Chop", "Spring", "Smoke", "Flame", "Ice", "Sand", "Dark", "Light", "Magma", "Quake", "String", "Bird", "Revive", "Paw", "Gravity"}
        return common[math.random(1, #common)]
    end
end

local function hookRoll()
    if game.ReplicatedStorage.RollFruit then
        local remote = game.ReplicatedStorage.RollFruit
        remote.OnClientInvoke = function()
            if isActive then
                local fruit = getRandomFruit()
                statusLabel.Text = "Lucky roll: " .. fruit .. " (1000x)"
                return fruit
            else
                if origRoll then return origRoll() end
            end
        end
    end
end

--[[
    BƯỚC 3: ANTIBAN
    A) Xóa logs gửi lên server
    B) Spoof tên script và execution
    C) Xóa dấu vết trong memory (hoặc fake version)
--]]
local function antiBan()
    -- Ẩn tên script khỏi game:Whitelist
    if game:IsLoaded() then
        local executor = getexecutorname or function() return "Unknown" end
        if executor == "Synapse X" or executor == "Krnl" then
            -- Gửi tín hiệu giả mạo version game hợp lệ
            local fakeVersion = "v2.4.1"
            local oldVersion = game.PlaceVersion
            game.PlaceVersion = 123456789 -- fake
            wait(0.5)
            game.PlaceVersion = oldVersion
        end
    end
    -- Chặn gửi thông báo lỗi tới server
    if game:GetService("LogService"):FindFirstChild("Out") then
        game:GetService("LogService").Out:Clear()
    end
    -- Xóa dấu vết trong ReplicatedStorage
    local function removeTraces()
        for _,v in pairs(game.ReplicatedStorage:GetChildren()) do
            if v.Name:lower():match("anticheat") or v.Name:lower():match("ban") then
                v:Destroy()
            end
        end
    end
    removeTraces()
    game.ReplicatedStorage.ChildAdded:Connect(function(child)
        if child.Name:lower():match("anticheat") or child.Name:lower():match("ban") then
            child:Destroy()
        end
    end)
end

--[[
    BƯỚC 4: KÍCH HOẠT TOÀN BỘ CHỨC NĂNG
    A) Đọc giá trị từ slider
