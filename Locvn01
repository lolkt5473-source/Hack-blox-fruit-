-- Hàm tạo các nút tính năng
local features = {}

local function addFeature(name, color, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9,0,0,40)
    btn.BackgroundColor3 = color or Color3.fromRGB(50,50,70)
    btn.Text = name .. " 🔘 OFF"
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.BackgroundTransparency = 0.3
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = btn
    btn.Parent = scroll
    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        btn.Text = name .. (active and " 🔴 ON" or " 🔘 OFF")
        btn.BackgroundColor3 = active and Color3.fromRGB(0,150,0) or color or Color3.fromRGB(50,50,70)
        callback(active)
    end)
    return btn
end

-- Hàm tạo thanh trượt
local function addSlider(name, min, max, default, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0.9,0,0,60)
    frame.BackgroundTransparency = 0.5
    frame.Parent = scroll
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,0,0,20)
    label.Text = name .. ": " .. default
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(200,200,200)
    label.Parent = frame
    local slider = Instance.new("TextBox")
    slider.Size = UDim2.new(1,0,0,30)
    slider.Position = UDim2.new(0,0,0,25)
    slider.Text = tostring(default)
    slider.BackgroundColor3 = Color3.fromRGB(40,40,50)
    slider.TextColor3 = Color3.fromRGB(255,255,255)
    slider.Parent = frame
    slider.FocusLost:Connect(function(enter)
        local val = tonumber(slider.Text)
        if val then
            val = math.clamp(val, min, max)
            slider.Text = tostring(val)
            label.Text = name .. ": " .. val
            callback(val)
        else
            slider.Text = tostring(default)
        end
    end)
end

