    isActive = true
    hookRoll()
    antiBan()
    statusLabel.Text = "ACTIVE | Lucky 1000x + AntiBan"
    -- Tạo vòng lặp giữ hook
    spawn(function()
        while isActive and gui.Parent do
            wait(30)
            antiBan()
            if not hookRoll then hookRoll() end
        end
    end)
end)

