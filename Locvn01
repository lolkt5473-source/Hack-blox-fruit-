-- Loop xử lý tính năng
local function onTick()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChild("Humanoid")
    if not hrp or not humanoid then return end

    -- Bay
    if fly then
        local cam = workspace.CurrentCamera
        local moveDir = Vector3.new()
        if mouse.Target then
            moveDir = (mouse.Hit.Position - hrp.Position).Unit
        end
        hrp.Velocity = moveDir * 60 + Vector3.new(0, cam.CFrame.UpVector.Y * 40, 0)
        humanoid.PlatformStand = true
    else
        if humanoid.PlatformStand then humanoid.PlatformStand = false end
    end

    -- Xuyên tường
    if noclip then
        hrp.CanCollide = false
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    else
        if hrp.CanCollide == false then hrp.CanCollide = true end
    end

    -- Tốc độ & nhảy
    humanoid.WalkSpeed = walkSpeed
    humanoid.JumpPower = jumpPower
    if infiniteJump then
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
    end

    -- Bất tử (god mode)
    if godMode then
        humanoid.Health = humanoid.MaxHealth
        humanoid.BreakJointsOnDeath = false
    end

    -- Một đòn chết: ghi đè damage
    if oneHit then
        local players = game.Players:GetPlayers()
        for _, p in pairs(players) do
            if p ~= player and p.Character and p.Character:FindFirstChild("Humanoid") then
                p.Character.Humanoid.Health = 0
            end
        end
        for _, mob in pairs(workspace:GetDescendants()) do
            if mob:IsA("Model") and mob:FindFirstChild("Humanoid") and mob.Name:lower():find("enemy") then
                mob.Humanoid.Health = 0
            end
        end
    end

    -- Auto farm coin (tìm vật phẩm có tên coin/gold/money)
    if autoFarm then
        for _, item in pairs(workspace:GetDescendants()) do
            if item:IsA("BasePart") and (item.Name:lower():find("coin") or item.Name:lower():find("gold") or item.Name:lower():find("money")) then
                if (hrp.Position - item.Position).Magnitude < 100 then
                    hrp.CFrame = item.CFrame
                    task.wait(0.05)
                end
            end
        end
    end

    -- Auto kill quái
    if autoKill then
        for _, mob in pairs(workspace:GetDescendants()) do
            if mob:IsA("Model") and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
                if (hrp.Position - mob:GetPivot().Position).Magnitude < 150 then
                    hrp.CFrame = mob:GetPivot() + Vector3.new(0, 3, 0)
                    task.wait()
                    mob.Humanoid.Health = 0
                end
            end
        end
    end

    -- Auto nhặt vật phẩm
    if autoCollect then
        for _, item in pairs(workspace:GetDescendants()) do
            if item:IsA("BasePart") and item:FindFirstChild("TouchInterest") and (hrp.Position - item.Position).Magnitude < 50 then
                hrp.CFrame = item.CFrame
                task.wait(0.05)
            end
        end
    end

    -- Teleport đến quái
    if teleportToMob then
        local nearestDist = math.huge
        local nearestMob = nil
        for _, mob in pairs(workspace:GetDescendants()) do
            if mob:IsA("Model") and mob:FindFirstChild("Humanoid") and (not mob:FindFirstChild("Humanoid") or mob.Humanoid.Health > 0) then
                local dist = (hrp.Position - mob:GetPivot().Position).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearestMob = mob
                end
            end
        end
        if nearestMob then
            hrp.CFrame = nearestMob:GetPivot() + Vector3.new(0, 3, 0)
        end
        teleportToMob = false -- tự tắt sau khi tele
    end
    if teleportToBoss then -- tương tự với boss
        -- tìm mob có tên boss
        for _, mob in pairs(workspace:GetDescendants()) do
            if mob:IsA("Model") and mob:FindFirstChild("Humanoid") and (mob.Name:lower():find("boss") or mob.Name:lower():find("king")) then
                hrp.CFrame = mob:GetPivot() + Vector3.new(0, 3, 0)
                break
            end
        end
        teleportToBoss = false
    end
    if teleportToChest then
        for _, chest in pairs(workspace:GetDescendants()) do
            if chest:IsA("BasePart") and (chest.Name:lower():find("chest") or chest.Name:lower():find("crate")) then
                hrp.CFrame = chest.CFrame + Vector3.new(0, 2, 0)
                break
            end
        end
        teleportToChest = false
    end
end

