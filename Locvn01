-- Hàm tạo nút bật/tắt
local function addToggle(name, color, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.92, 0, 0, 38)
    btn.BackgroundColor3 = color or Color3.fromRGB(60, 60, 90)
    btn.Text = name .. " 🔘 TẮT"
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.BackgroundTransparency = 0.2
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = btn
    btn.Parent = scroll
    local state = false
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = name .. (state and " 🔴 BẬT" or " 🔘 TẮT")
        btn.BackgroundColor3 = state and Color3.fromRGB(0, 150, 0) or color or Color3.fromRGB(60, 60, 90)
        callback(state)
    end)
    return btn
end

-- Hàm tạo thanh trượt
local function addSlider(name, minVal, maxVal, defaultVal, callback)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(0.92, 0, 0, 55)
    container.BackgroundTransparency = 0.8
    container.Parent = scroll
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 20)
    label.Text = name .. ": " .. tostring(defaultVal)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(220, 220, 220)
    label.Parent = container
    local slider = Instance.new("TextBox")
    slider.Size = UDim2.new(1, 0, 0, 25)
    slider.Position = UDim2.new(0, 0, 0, 25)
    slider.Text = tostring(defaultVal)
    slider.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    slider.TextColor3 = Color3.fromRGB(255, 255, 255)
    slider.Parent = container
    slider.FocusLost:Connect(function()
        local val = tonumber(slider.Text)
        if val then
            val = math.clamp(val, minVal, maxVal)
            slider.Text = tostring(val)
            label.Text = name .. ": " .. val
            callback(val)
        else
            slider.Text = tostring(defaultVal)
        end
    end)
end

